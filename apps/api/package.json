{
  "name": "@brimble/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --clean --target node22",
    "start": "node dist/index.js",
    "test": "node --import tsx --test --test-concurrency=1 test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "latest",
    "better-sqlite3": "latest",
    "dockerode": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "nanoid": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "simple-git": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/dockerode": "latest",
    "@types/node": "latest",
    "drizzle-kit": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
